<p class="login-box-msg"><%= t('devise.registrations.new.sign_up') %></p>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), data: { turbo: false }) do |f| %>
  <%= devise_error_messages! %>

  <div class="input-group mb-3">
    <%= f.email_field :email, autofocus: true, class: "form-control", placeholder: resource.class.human_attribute_name(:email) %>
    <div class="input-group-append">
      <div class="input-group-text">
        <span class="fas fa-envelope"></span>
      </div>
    </div>
  </div>

  <div class="input-group mb-3">
    <%= f.password_field :password, autocomplete: "off", class: "form-control", placeholder: resource.class.human_attribute_name(:password) %>
    <div class="input-group-append">
      <div class="input-group-text">
        <span class="fas fa-lock"></span>
      </div>
    </div>
  </div>

  <div class="input-group mb-3">
    <%= f.password_field :password_confirmation, autocomplete: "off", class: "form-control", placeholder: resource.class.human_attribute_name(:password) %>
    <div class="input-group-append">
      <div class="input-group-text">
        <span class="fas fa-lock"></span>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-12">
      <%= f.submit t('devise.registrations.new.sign_up'), class: "btn btn-primary btn-block" %>
    </div>
    <!-- /.col -->
  </div>

<% end %>

<%= render "admins/shared/links" %>
