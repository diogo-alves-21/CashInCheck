<!DOCTYPE html>
<html>
  <head>
    <title>Styleguide</title>
    <%= csrf_meta_tags %>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%#= favicon_link_tag 'favicon.ico' %>

    <%= stylesheet_link_tag '/stylesheets/application', media: 'all', 'data-turbo-track': 'reload' %>
    <%#= stylesheet_link_tag 'styleguide', media: 'all', 'data-turbo-track': 'reload' %>
    <%= stylesheet_link_tag '/stylesheets/styleguide', media: 'all', 'data-turbo-track': 'reload' %>
    <%= javascript_include_tag '/javascript/styleguide', 'data-turbo-track': 'reload' %>
    <!-- <link rel="stylesheet" href="styleguide/styleguide.css" crossorigin="anonymous" /> -->

    <!-- <script src="styleguide/jquery-2.2.4.min.js"></script> -->

    <%#= javascript_include_tag 'styleguide', 'data-turbo-track': 'reload' %>
    <link href="styleguide/emoji-css-afeld.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">

    <!-- <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.17.1/themes/prism.min.css" integrity="sha256-77qGXu2p8NpfcBpTjw4jsMeQnz0vyh74f5do0cWjQ/Q=" crossorigin="anonymous" /> -->
    <link rel="stylesheet" href="styleguide/prism.css" crossorigin="anonymous" />

    <link href="https://cdn.jsdelivr.net/npm/select2@4.0.13/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.0.13/dist/js/select2.min.js"></script>



  </head>

  <body id="styleguide_rails">
    <nav class="styleguide__menu-sidenav">
      <div id="my_side_nav" class="styleguide__burger-box">
        <div class="styleguide__burger-sidenav"><span></span></div>
      </div>

      <div class="styleguide__rails-title">
        <%= link_to styleguide_path, 'data-no-turbolink' => true, class: "styleguide__nav-title" do %>
        Styleguide
        <% end %>
      </div>

      <div class="styleguide__sidenav">
        <ul class="styleguide__nav-list">
          <li class="<%= "styleguide__selected" if params[:page].blank? %>"><%= link_to "Styleguide", styleguide_path %></li>
          <li class="<%= "styleguide__selected" if params[:page] == "colors" %>"><%= link_to "Colors", styleguide_path(page: "colors") %></li>
          <li class="<%= "styleguide__selected" if params[:page] == "variables" %>"><%= link_to "Variables", styleguide_path(page: "variables") %></li>
          <li class="<%= "styleguide__selected" if params[:page] == "buttons" %>"><%= link_to "Buttons", styleguide_path(page: "buttons") %></li>
          <li class="<%= "styleguide__selected" if params[:page] == "fonts" %>"><%= link_to "Fonts", styleguide_path(page: "fonts") %></li>
          <li class="<%= "styleguide__selected" if params[:page] == "forms" %>"><%= link_to "Forms", styleguide_path(page: "forms") %></li>
          <li class="<%= "styleguide__selected" if params[:page] == "navigation" %>"><%= link_to "Navigation", styleguide_path(page: "navigation") %></li>
          <li class="<%= "styleguide__selected" if params[:page] == "utility_classes" %>"><%= link_to "Utility Classes", styleguide_path(page: "utility_classes") %></li>
          <li class="<%= "styleguide__selected" if params[:page] == "mixins" %>"><%= link_to "Mixins", styleguide_path(page: "mixins") %></li>
          <!--li class="<%#= "styleguide__selected" if params[:page] == "utilities" %>"><%#= link_to "Utilities", styleguide_path(page: "utilities") %></li-->
          <li class="<%= "styleguide__selected" if params[:page] == "susy" %>"><%= link_to "Susy", styleguide_path(page: "susy") %></li>
          <li class="<%= "styleguide__selected" if params[:page] == "guidelines" %>"><%= link_to "Guidelines", styleguide_path(page: "guidelines") %></li>
        </ul>
      </div>
    </nav>
    <div class="styleguide__container">

      <% if params[:page].present? %>
        <%= render "styleguide/partials/#{params[:page]}" %>
      <% else %>
        <%= render 'styleguide/partials/index' %>
      <% end %>

    </div>
  </body>

  <script src="styleguide/styleguide.js"></script>

  <script src="styleguide/prism.min.js"></script>
  <script src="styleguide/prism-markup.min.js"></script>
  <script src="styleguide/prism-scss.min.js"></script>
  <script src="styleguide/prism-unescaped-markup.min.js"></script>
  <!-- <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.17.1/components/prism-erb.min.js" integrity="sha256-a3LUkP+U0/upYKDwxeKylQPoMuvRJI8ugle49HgFhmg=" crossorigin="anonymous"></script> -->
  <script src="styleguide/prism-ruby.min.js"></script>
  <script src="styleguide/prism-markup-templating.min.js"></script>
  <script src="styleguide/prism-erb.min.js"></script>

</html>
