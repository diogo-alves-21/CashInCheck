<% container_title = Admin.model_name.human(count: 0) %>
<% content_for :title, container_title %>
<%= render 'mazer_partials/container', title: container_title do %>

  <%= render 'mazer_partials/box/box', title: t('views.mazer.action.index'), buttons: [
        { name: t('views.mazer.new'), url: new_admin_admin_path, new_button: true }
      ] do %>

    <!-- <div class="card-body"> -->
      <!-- INSERT FILTERS HERE -->
    <!-- </div> -->

    <%= render 'mazer_partials/box/body' do %>
      <%= render 'mazer_partials/table/table', paginate_object: @pagy do %>
        <thead>
          <tr>
            <th><%= Admin.human_attribute_name(:email) %></th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @admins.each do |admin| %>
            <tr>
              <td><%= admin.email %></td>
              <td class="text-end">
                <%= render partial: 'mazer_partials/table/buttons', locals: {
                  buttons: [
                    { name: t("views.mazer.show"), url: [:admin, admin] },
                    { name: t("views.mazer.edit"), url: edit_admin_admin_path(admin) },
                    { name: t("views.mazer.destroy"), url: [:admin, admin] }
                  ]
                } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      <% end %>
    <% end %>
  <% end %>
<% end %>
