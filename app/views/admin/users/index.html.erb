<% container_title = User.model_name.human(count: 0) %>
<% content_for :title, container_title %>
<%= render 'mazer_partials/container', title: container_title do %>

  <%= render 'mazer_partials/box/box', title: t('views.mazer.action.index'), buttons: [
    {name: t('views.mazer.new'), url: new_admin_user_path, new_button: true },
  ] do %>
    <%= render 'mazer_partials/box/body' do %>

      <%= render 'mazer_partials/table/table', paginate_object: @pagy do %>
        <thead>
        <tr>
          <th><%= User.human_attribute_name(:email) %></th>
          <th><%= User.human_attribute_name(:created_at) %></th>
          <th></th>
        </tr>
        </thead>
        <tbody>
        <% @users.each do |user| %>
          <tr>
            <td><%= user.email %></td>
            <td><%= user.created_at %></td>
            <td class="text-right">
              <%= render partial: 'mazer_partials/table/buttons', locals: {
                buttons: [
                  { name: t("views.mazer.show"), url: [:admin, user] },
                  { name: t("views.mazer.edit"), url: edit_admin_user_path(user) },
                  { name: t("views.mazer.destroy"), url: [:admin, user] },
                ]
              } %>
            </td>
          </tr>
        <% end %>
        </tbody>
      <% end %>
    <% end %>
  <% end %>
<% end %>

