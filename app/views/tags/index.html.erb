<%= render 'layout_partials/header',
  page_title: Tag.model_name.human(count: 0),
  page_subtitle: @group.name %>


<div class="cic-table">
  <div class="box">
    <div class="cic-table m-t-3 m-b-2">
      <% @tags.each do |tag| %>
        <div class="cic-table__row">
          <h5><%= tag.name %></h5>
          <%= link_to edit_group_tag_path(@group.id, tag), class: 'd-flex align-center gap-1' do %>
            <i class="cic-icon-edit fs-h5"></i>
            <%= t('views.edit') %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<% @left_buttons = [
    { icon: 'cic-icon-arrow---left-2', url: group_path(@group), extraClass: 'btn-icon back-link' }
  ]  %>

<% @right_buttons = [
    { icon: 'cic-icon-plus', url: new_group_tag_path, extraClass: 'btn-icon action new btn--extra-large', primary: true }
  ]  %>
